#!/bin/bash
# pencil-mcp - Wrapper script para Pencil MCP Server
# Coloca este script em ~/.local/bin/pencil-mcp

set -e

# Procura o MCP server em locais possíveis
search_paths=(
  "$HOME/.local/share/pencil"
  "/tmp/.mount_Pencil"*
)

for path in "${search_paths[@]}"; do
  if [ -d "$path" ]; then
    MCP_SERVER=$(find "$path" -name "mcp-server-linux-x64" -type f 2>/dev/null | head -1)
    if [ -n "$MCP_SERVER" ]; then
      exec "$MCP_SERVER" --app desktop
    fi
  fi
done

# Fallback: tenta AppImage
if [ -f "$HOME/.local/bin/Pencil-linux-x86_64.AppImage" ]; then
  "$HOME/.local/bin/Pencil-linux-x86_64.AppImage" --app desktop &
  sleep 3
  for path in /tmp/.mount_Pencil*; do
    if [ -d "$path" ]; then
      MCP_SERVER=$(find "$path" -name "mcp-server-linux-x64" 2>/dev/null | head -1)
      if [ -n "$MCP_SERVER" ]; then
        exec "$MCP_SERVER" --app desktop
      fi
    fi
  done
fi

echo "Error: Pencil MCP server not found" >&2
exit 1
