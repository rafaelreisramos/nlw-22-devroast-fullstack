{
	"$schema": "https://opencode.ai/config.json",
	"mcp": {
		"context7": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp"
		},
		"pencil": {
			"command": ["bash", "-c", "$HOME/.pencil-mcp/pencil-mcp-wrapper.sh"],
			"enabled": true,
			"type": "local"
		},
		"playwright": {
			"type": "local",
			"command": ["npx", "@playwright/mcp@latest"],
			"enabled": true
		}
	}
}
